# Environment Configuration for Prompt Optimization
# ====================================================
#
# Copy this file to .env and fill in your API keys
# The optimization system supports multiple LLM providers

# ============================================================================
# PRIMARY PROVIDER (One Required - use one that's available)
# ============================================================================

# Option 1: Google Gemini (Free tier available)
GEMINI_API_KEY=your-gemini-api-key-here

# Option 2: AWS Bedrock / Claude
AWS_ACCESS_KEY_ID=your-aws-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1
DEFAULT_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0

# Option 3: Groq (Free API)
GROQ_API_KEY=your-groq-api-key-here

# Option 4: Cerebras
CEREBRAS_API_KEY=your-cerebras-api-key-here

# ============================================================================
# OPTIMIZATION SETTINGS
# ============================================================================

# Default provider to use if not specified in code
LLM_PROVIDER=gemini

# Watermark secret (customize for your experiments)
WATERMARK_SECRET=default-key-2024

# Minimum green set size (8 = 8 letters preferred)
GREEN_SET_MIN=8

# Maximum green set size (18 = up to 18 letters preferred)
GREEN_SET_MAX=18

# ============================================================================
# PATHS
# ============================================================================

# Dataset location (relative to project root)
HUMANEVAL_DATASET=datasets/humaneval-sample.json
MBPP_DATASET=datasets/sanitized-mbpp.json

# Results output directory
RESULTS_DIR=results

# ============================================================================
# OPTIMIZATION DEFAULTS
# ============================================================================

# Number of samples for baseline evaluation (higher = more reliable, slower)
BASELINE_SAMPLES=20

# Number of samples per variant (higher = more reliable, slower)
VARIANT_SAMPLES=10

# Run Bayesian tuning automatically if improvement detected
AUTO_BAYESIAN=false

# Temperature for LLM generation (0.1 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.1

# Max tokens per generation
MAX_TOKENS=2048

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. API Key Setup:
#    - Gemini: Free! Get at https://ai.google.dev/
#    - Claude: AWS Bedrock account (paid, ~$0.003 per 1k input tokens)
#    - Groq: Free! Get at https://console.groq.com/
#    - Cerebras: Paid, Get at https://cloud.cerebras.ai/
#
# 2. Recommended for testing:
#    - Start with GEMINI_API_KEY (free tier available)
#    - Then test GROQ_API_KEY (also free, faster inference)
#
# 3. File location:
#    - Keep this file in project root as .env
#    - Never commit .env to git
#
# 4. Environment variables:
#    - Python's python-dotenv loads these automatically
#    - Or set manually: export GEMINI_API_KEY='...'
